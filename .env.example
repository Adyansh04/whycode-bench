# Environment variables for docker-compose
# Copy this file to .env and modify as needed:
#   cp .env.example .env

# Compose project name shown by `docker compose ps`
COMPOSE_PROJECT_NAME=ros2_project_template

# ROS distribution (jazzy, humble, iron, etc.)
ROS_DISTRO=jazzy

# Upstream base image: <BASE_IMAGE_REPO>:<ROS_DISTRO><BASE_IMAGE_TAG_SUFFIX>
BASE_IMAGE_REPO=adyansh04/ros-dev
BASE_IMAGE_TAG_SUFFIX=-latest

# Derived dev image built from .devcontainer/Dockerfile
DEV_IMAGE_REPO=adyansh04/ros-dev-workspace

# Container naming prefix: <CONTAINER_PREFIX>_<ROS_DISTRO>
CONTAINER_PREFIX=ros_dev

# Display for GUI applications (usually inherited from host)
# DISPLAY=:0
